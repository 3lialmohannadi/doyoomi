{
  "expo": {
    "name": "Do.Yoomi — يومي",
    "slug": "doyoomi",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "doyoomi",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#6366F1"
    },
    "ios": {
      "supportsTablet": false,
      "buildNumber": "23",
      "bundleIdentifier": "com.doyoomi.app"
    },
    "android": {
      "package": "com.doyoomi.app",
      "versionCode": 1
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "769ce4cc-6ced-4bd1-8352-54880949b0ef"
      }
    }
  }
}
